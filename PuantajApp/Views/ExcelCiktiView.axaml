<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PuantajApp.ViewModels"
             x:Class="PuantajApp.Views.ExcelCiktiView"
             x:DataType="vm:ExcelCiktiViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="16">
        <!-- Baslik -->
        <TextBlock Grid.Row="0" Text="EXCEL CIKTI OLUSTUR" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Parametreler -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,90,Auto,90,Auto,90,Auto,120" Margin="0,0,0,16">
            <TextBlock Grid.Column="0" Text="Ay:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <NumericUpDown Grid.Column="1" Value="{Binding Ay}" Minimum="1" Maximum="12"/>
            <TextBlock Grid.Column="2" Text="Yil:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <NumericUpDown Grid.Column="3" Value="{Binding Yil}" Minimum="2020" Maximum="2030"/>
            <TextBlock Grid.Column="4" Text="Is Gunu:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <NumericUpDown Grid.Column="5" Value="{Binding IsGunu}" Minimum="1" Maximum="31"/>
            <TextBlock Grid.Column="6" Text="Yemek Br:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <NumericUpDown Grid.Column="7" Value="{Binding YemekBirimUcreti}" Minimum="0" Maximum="9999"/>
        </Grid>

        <!-- Kayit Yolu -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
            <TextBlock Grid.Column="0" Text="Kayit Yeri:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding KayitYolu}"/>
            <Button Grid.Column="2" Content="Sec..." Name="BtnKayitYoluSec" Margin="8,0,0,0"/>
        </Grid>

        <!-- Butonlar -->
        <StackPanel Grid.Row="3" Spacing="16" Margin="0,0,0,8">
            <Button Content="Puantaj Excel Olustur" Command="{Binding PuantajExcelOlusturCommand}" Width="200"/>
            <Button Content="Hakedis Kapak Excel Olustur" Command="{Binding HakedisExcelOlusturCommand}" Width="220"/>
        </StackPanel>

        <!-- Durum -->
        <TextBlock Grid.Row="4" Text="{Binding Durum}" Foreground="Blue" Margin="0,8,0,0"/>
    </Grid>
</UserControl>

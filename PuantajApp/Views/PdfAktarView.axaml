<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PuantajApp.ViewModels"
             x:Class="PuantajApp.Views.PdfAktarView"
             x:DataType="vm:PdfAktarViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">
        <!-- Baslik + AI Backend Bilgisi -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="&#x1F916; AI PDF Otomatik Parse" Classes="sectionHeader"/>
            <Border Grid.Column="1" Background="{StaticResource AccentLightBrush}"
                    CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                <TextBlock Text="{Binding AiBackend}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentHoverBrush}"/>
            </Border>
        </Grid>

        <!-- Ayarlar -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,80,Auto,90,Auto,*,Auto,Auto" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="Ay" Classes="label" Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1" Value="{Binding Ay}" Minimum="1" Maximum="12" FormatString="0"/>
                <TextBlock Grid.Column="2" Text="Yil" Classes="label" Margin="12,0,8,0"/>
                <NumericUpDown Grid.Column="3" Value="{Binding Yil}" Minimum="2020" Maximum="2030" FormatString="0"/>
                <TextBlock Grid.Column="4" Text="&#x1F511; API Key" Classes="label" Margin="16,0,8,0"/>
                <TextBox Grid.Column="5" Text="{Binding GeminiApiKey}"
                         Watermark="Gemini API Key girin (aistudio.google.com/apikey)" PasswordChar="*"/>
                <Button Grid.Column="6" Content="&#x1F4C2; PDF Sec..." Classes="secondary" Name="BtnPdfSec" Margin="8,0,0,0"/>
                <Button Grid.Column="7" Content="&#x25B6; Tumu Parse Et" Classes="primary"
                        Command="{Binding TumunuParseEtCommand}"
                        IsEnabled="{Binding !Isleniyor}"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- PDF Listesi -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Pdfler}"
                  SelectedItem="{Binding SecilenPdf}"
                  IsReadOnly="False"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Sec" Binding="{Binding Secili}" Width="50"/>
                <DataGridTextColumn Header="Dosya Adi" Binding="{Binding DosyaAdi}" Width="250" IsReadOnly="True"/>
                <DataGridTextColumn Header="Durum" Binding="{Binding Durum}" Width="180" IsReadOnly="True"/>
                <DataGridTextColumn Header="Eslesen Personel" Binding="{Binding EslesenPersonel}" Width="200" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Islem" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:PdfOgesiViewModel">
                            <Button Content="&#x2705; Onayla+Kaydet" Classes="primary" FontSize="11" Padding="8,4"
                                    Command="{Binding $parent[DataGrid].((vm:PdfAktarViewModel)DataContext).OnaylaVeKaydetCommand}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Progress + Durum -->
        <Border Grid.Row="3" Classes="card" Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Durum}" Classes="statusInfo" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                    <TextBlock Text="Toplam:" Classes="label"/>
                    <TextBlock Text="{Binding Pdfler.Count}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                    <TextBlock Text="&#x2705;" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Basarili}" Classes="statusSuccess" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                    <TextBlock Text="&#x274C;" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Hata}" Classes="statusError" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PuantajApp.ViewModels"
             x:Class="PuantajApp.Views.PuantajView"
             x:DataType="vm:PuantajViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">
        <!-- Baslik -->
        <TextBlock Grid.Row="0" Text="Puantaj Girisi" Classes="sectionHeader"/>

        <!-- Filtre -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,90,Auto,90,Auto,*">
                <TextBlock Grid.Column="0" Text="Ay" Classes="label" Margin="0,0,8,0"/>
                <NumericUpDown Grid.Column="1" Value="{Binding Ay}" Minimum="1" Maximum="12" FormatString="0"/>
                <TextBlock Grid.Column="2" Text="Yil" Classes="label" Margin="12,0,8,0"/>
                <NumericUpDown Grid.Column="3" Value="{Binding Yil}" Minimum="2020" Maximum="2030" FormatString="0"/>
                <TextBlock Grid.Column="4" Text="Personel" Classes="label" Margin="12,0,8,0"/>
                <ComboBox Grid.Column="5"
                          ItemsSource="{Binding Personeller}"
                          SelectedItem="{Binding SecilenPersonel}"
                          DisplayMemberBinding="{Binding AdSoyad}"/>
            </Grid>
        </Border>

        <!-- Puantaj Tablosu -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Satirlar}"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="False"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Gun" Binding="{Binding Gun}" Width="45" IsReadOnly="True"/>
                <DataGridTextColumn Header="Tip" Binding="{Binding GunTipiGoster}" Width="40" IsReadOnly="True"/>
                <DataGridTextColumn Header="Giris" Binding="{Binding GirisSaati}" Width="65"/>
                <DataGridTextColumn Header="Cikis" Binding="{Binding CikisSaati}" Width="65"/>
                <DataGridTextColumn Header="Mi/Yi/R" Binding="{Binding IzinTipi}" Width="60"/>
                <DataGridTextColumn Header="FM Grs" Binding="{Binding FmGiris}" Width="65"/>
                <DataGridTextColumn Header="FM Cks" Binding="{Binding FmCikis}" Width="65"/>
                <DataGridTextColumn Header="FM St" Binding="{Binding FmSaat, StringFormat={}{0:F2}}" Width="60"/>
                <DataGridTextColumn Header="Sure" Binding="{Binding HesaplananSure, StringFormat={}{0:F2}}" Width="55" IsReadOnly="True"/>
                <DataGridTextColumn Header="Yemek" Binding="{Binding YemekHakki}" Width="55" IsReadOnly="True"/>
                <DataGridTextColumn Header="Aciklama" Binding="{Binding Aciklama}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Ozet kartlari -->
        <Border Grid.Row="3" Classes="card" Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ToplamSure, StringFormat='{}{0:F2}'}" Classes="statValue"/>
                    <TextBlock Text="Toplam Sure (saat)" Classes="statLabel"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ToplamYemek}" Classes="statValue"/>
                    <TextBlock Text="Yemek (gun)" Classes="statLabel"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ToplamFm, StringFormat='{}{0:F2}'}" Classes="statValue"/>
                    <TextBlock Text="FM (saat)" Classes="statLabel"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ToplamRtFm, StringFormat='{}{0:F2}'}" Classes="statValue"/>
                    <TextBlock Text="RT FM (saat)" Classes="statLabel"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Alt bar -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Durum}" Classes="statusInfo" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="&#x1F4BE; Kaydet" Classes="primary" Command="{Binding KaydetCommand}"/>
        </Grid>
    </Grid>
</UserControl>
